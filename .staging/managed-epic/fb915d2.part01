diff --git a/src/client_cli.go b/src/client_cli.go
new file mode 100644
index 0000000..19e5c96
--- /dev/null
+++ b/src/client_cli.go
@@ -0,0 +1,196 @@
+package yarouter
+
+import (
+	"context"
+	"encoding/json"
+	"errors"
+	"flag"
+	"fmt"
+	"io"
+	"net"
+	"net/http"
+	"os"
+	"path/filepath"
+	"strconv"
+	"strings"
+	"time"
+
+	clientpkg "github.com/duvu/ya-router/internal/client"
+)
+
+const (
+	clientExitSuccess       = 0
+	clientExitGeneric       = 1
+	clientExitUsage         = 2
+	clientExitAuthorization = 3
+	clientExitCompatibility = 4
+	clientExitConflict      = 5
+	clientExitConnection    = 6
+)
+
+func ExecuteClient(args []string) int {
