++func TestTUIOfflineStateIsTextualAndSanitized(t *testing.T) {
++\tmodel := newTUIModel(fakeTUIClient{err: &controlClientTestError{}})
++\tmessage := model.loadCmd(false)()
++\tupdated, _ := model.Update(message)
++\tview := updated.(tuiModel).View()
++\tif !strings.Contains(view, "OFFLINE") || !strings.Contains(view, "request_id=req_test") {
++\t\tt.Fatalf("offline state lacks textual diagnostics: %s", view)
++\t}
++\tfor _, secret := range []string{"api_key", "access_token", "secret-value"} {
++\t\tif strings.Contains(view, secret) {
++\t\t\tt.Fatalf("TUI leaked %q: %s", secret, view)
++\t\t}
++\t}
++}
