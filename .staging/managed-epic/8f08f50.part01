++func TestTUIRenderGoldenTerminalClasses(t *testing.T) {
++\tsnapshot := sampleTUISnapshot()
++\tfor _, terminal := range []struct {
++\t\tname   string
++\t\twidth  int
++\t\theight int
++\t}{
++\t\t{name: "compact", width: 40, height: 16},
++\t\t{name: "standard", width: 80, height: 24},
++\t\t{name: "wide", width: 120, height: 32},
++\t} {
++\t\tt.Run(terminal.name, func(t *testing.T) {
++\t\t\tmodel := newTUIModel(fakeTUIClient{snapshot: snapshot})
++\t\t\tmodel.theme = themeMonochrome
++\t\t\tmodel.loading = false
++\t\t\tmodel.data = snapshot
++\t\t\tmodel.width = terminal.width
++\t\t\tmodel.height = terminal.height
++\t\t\tgot := model.View()
++\t\t\tpath := filepath.Join("testdata", "tui", terminal.name+".golden")
++\t\t\tif os.Getenv("UPDATE_GOLDEN") == "1" {
++\t\t\t\tif err := os.WriteFile(path, []byte(got), 0o600); err != nil {
++\t\t\t\t\tt.Fatal(err)
++\t\t\t\t}
++\t\t\t}
++\t\t\twant, err := os.ReadFile(path)
++\t\t\tif err != nil {
++\t\t\t\tt.Fatal(err)
++\t\t\t}
++\t\t\tif got != string(want) {
++\t\t\t\tt.Fatalf("render mismatch for %s\n--- got ---\n%s\n--- want ---\n%s", terminal.name, got, want)
++\t\t\t}
++\t\t\tif strings.Contains(got, "\x1b[") {
++\t\t\t\tt.Fatal("monochrome render contains ANSI color escapes")
++\t\t\t}
++\t\t})
++\t}
++}
