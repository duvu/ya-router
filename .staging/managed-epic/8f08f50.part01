+\tif len(lines) == 1 {
+\t\tlines = append(lines, "No provider data.")
+\t}
+\treturn cropTUILines(lines, model.height-6)
+}
+
+func (model tuiModel) renderAccounts(styles tuiStyles) string {
+\tlines := []string{styles.section.Render("Accounts")}
+\tfor _, account := range model.data.accounts {
+\t\tstate := "disabled"
+\t\tif account.Enabled {
+\t\t\tstate = "enabled"
+\t\t}
+\t\tcredential := "not configured"
+\t\tif account.Credential.Configured {
+\t\t\tcredential = "configured via " + emptyFallback(account.Credential.Source, "unknown")
+\t\t}
+\t\tlines = append(lines, fmt.Sprintf("[%s] %s/%s label=%q priority=%d credential=%s", state, account.ProviderID, account.ID, account.Label, account.Priority, credential))
+\t}
+\tif len(lines) == 1 {
+\t\tlines = append(lines, "No account data.")
+\t}
+\treturn cropTUILines(lines, model.height-6)
+}
+
+func (model tuiModel) renderModels(styles tuiStyles) string {
+\tlines := []string{styles.section.Render("Models")}
+\tfor _, catalog := range model.data.models.Catalogs {
+\t\tstatus := "fresh"
+\t\tif catalog.Stale {
+\t\t\tstatus = "stale"
+\t\t}
+\t\tif !catalog.Available {
+\t\t\tstatus = "unavailable"
+\t\t}
+\t\tlines = append(lines, fmt.Sprintf("%s [%s] age=%ds", catalog.ProviderID, status, catalog.AgeSeconds))
+\t\tfor _, model := range catalog.Models {
+\t\t\tavailability := "unavailable"
+\t\t\tif model.Available {
+\t\t\t\tavailability = "available"
+\t\t\t}
+\t\t\tlines = append(lines, fmt.Sprintf("  [%s] %s", availability, model.ID))
+\t\t}
+\t}
+\tif len(lines) == 1 {
+\t\tlines = append(lines, "No model data.")
+\t}
+\treturn cropTUILines(lines, model.height-6)
+}
+
+func (model tuiModel) renderConfig(styles tuiStyles) string {
+\tlines := []string{styles.section.Render("Configuration"),
+\t\tfmt.Sprintf("Revision: %d", model.data.configuration.Revision),
+\t\tfmt.Sprintf("Digest: %s", emptyFallback(model.data.configuration.Digest, "unknown")),
+\t\tfmt.Sprintf("Restart required: %s", joinStrings(model.data.configuration.RestartRequired)),
+\t}
+\tif model.data.configuration.Desired != nil {
+\t\tlines = append(lines,
+\t\t\tfmt.Sprintf("Default provider: %s", model.data.configuration.Desired.Routing.DefaultProvider),
+\t\t\tfmt.Sprintf("Default model: %s", model.data.configuration.Desired.Routing.DefaultModel))
+\t}
+\treturn cropTUILines(lines, model.height-6)
+}
+
+func (model tuiModel) renderOperations(styles tuiStyles) string {
+\tlines := []string{styles.section.Render("Operations")}
+\toperations := append([]controlpkg.OperationResource(nil), model.data.operations...)
+\tsort.SliceStable(operations, func(left, right int) bool { return operations[left].UpdatedAt.After(operations[right].UpdatedAt) })
+\tfor _, operation := range operations {
+\t\tlines = append(lines, fmt.Sprintf("[%s] %s kind=%s progress=%d%% updated=%s", operation.State, operation.ID, operation.Kind, operation.Progress, operation.UpdatedAt.Format(time.RFC3339)))
+\t}
+\tif len(lines) == 1 {
+\t\tlines = append(lines, "No operations.")
+\t}
+\treturn cropTUILines(lines, model.height-6)
+}
+
+func (model tuiModel) renderEvents(styles tuiStyles) string {
+\tlines := []string{styles.section.Render("Lifecycle events")}
+\tfor _, event := range model.data.events.Data {
+\t\tlines = append(lines, fmt.Sprintf("#%d %s provider=%s generation=%d", event.Sequence, event.Type, event.ProviderID, event.Generation))
+\t}
+\tif len(lines) == 1 {
+\t\tlines = append(lines, "No events.")
+\t}
+\treturn cropTUILines(lines, model.height-6)
+}
+
+func (model tuiModel) loadCmd(refreshModels bool) tea.Cmd {
+\treturn func() tea.Msg {
+\t\tif model.client == nil {
+\t\t\treturn tuiErrorMsg{err: errors.New("control client is not configured")}
+\t\t}
+\t\tctx, cancel := context.WithTimeout(context.Background(), 20*time.Second)
+\t\tdefer cancel()
+\t\tmeta, err := model.client.Meta(ctx)
+\t\tif err != nil {
+\t\t\treturn tuiErrorMsg{err: err}
+\t\t}
+\t\tproviders, err := model.client.Providers(ctx)
+\t\tif err != nil {
+\t\t\treturn tuiErrorMsg{err: err}
+\t\t}
+\t\taccounts, err := model.client.Accounts(ctx)
+\t\tif err != nil {
+\t\t\treturn tuiErrorMsg{err: err}
+\t\t}
+\t\tmodels, err := model.client.Models(ctx, refreshModels)
+\t\tif err != nil {
+\t\t\treturn tuiErrorMsg{err: err}
+\t\t}
+\t\tconfiguration, err := model.client.Configuration(ctx)
+\t\tif err != nil {
+\t\t\treturn tuiErrorMsg{err: err}
+\t\t}
+\t\toperations, err := model.client.Operations(ctx)
+\t\tif err != nil {
+\t\t\treturn tuiErrorMsg{err: err}
+\t\t}
+\t\tevents, err := model.client.Events(ctx, 0)
+\t\tif err != nil {
+\t\t\treturn tuiErrorMsg{err: err}
+\t\t}
+\t\treturn tuiLoadedMsg{snapshot: tuiSnapshot{meta: meta, providers: providers, accounts: accounts, models: models, configuration: configuration, operations: operations, events: events, loadedAt: time.Now().UTC()}}
+\t}
+}
+
+func tuiTickCmd() tea.Cmd {
+\treturn tea.Tick(10*time.Second, func(now time.Time) tea.Msg { return tuiTickMsg(now) })
+}
+
+type tuiStyles struct{ title, section, active, error lipgloss.Style }
+
+func tuiStylesFor(theme tuiTheme) tuiStyles {
+\tstyles := tuiStyles{title: lipgloss.NewStyle().Bold(true), section: lipgloss.NewStyle().Bold(true), active: lipgloss.NewStyle().Bold(true), error: lipgloss.NewStyle().Bold(true)}
+\tif theme == themeMonochrome {
+\t\treturn styles
+\t}
+\tif theme == themeLight {
+\t\tstyles.title = styles.title.Foreground(lipgloss.Color("18"))
+\t\tstyles.active = styles.active.Foreground(lipgloss.Color("24"))
+\t\tstyles.error = styles.error.Foreground(lipgloss.Color("124"))
+\t\treturn styles
+\t}
+\tstyles.title = styles.title.Foreground(lipgloss.Color("81"))
+\tstyles.active = styles.active.Foreground(lipgloss.Color("86"))
+\tstyles.error = styles.error.Foreground(lipgloss.Color("203"))
+\treturn styles
+}
+
+func executeTUI(client *clientpkg.Client, stdout, stderr io.Writer) int {
+\tprogram := tea.NewProgram(newTUIModel(client), tea.WithOutput(stdout), tea.WithAltScreen())
+\tif _, err := program.Run(); err != nil {
+\t\tfmt.Fprintf(stderr, "ya: TUI failed: %v\n", sanitizeTUIError(err))
+\t\treturn clientExitGeneric
+\t}
+\treturn clientExitSuccess
+}
+
+func sanitizeTUIError(err error) error {
+\tif err == nil {
+\t\treturn nil
+\t}
+\tvar apiError *clientpkg.APIError
+\tif errors.As(err, &apiError) {
+\t\treturn apiError
+\t}
+\ttext := strings.TrimSpace(err.Error())
+\tif text == "" {
+\t\ttext = "control service is unavailable"
+\t}
+\tif len(text) > 240 {
+\t\ttext = text[:240] + "…"
+\t}
+\treturn errors.New(text)
+}
+
+func cropTUILines(lines []string, limit int) string {
+\tif limit < 1 {
+\t\tlimit = 1
+\t}
+\tif len(lines) > limit {
+\t\tlines = append(append([]string(nil), lines[:limit-1]...), fmt.Sprintf("… %d more", len(lines)-limit+1))
+\t}
+\treturn strings.Join(lines, "\n")
+}
+func fitTUILine(value string, width int) string {
+\tif width < 2 || len([]rune(value)) <= width {
+\t\treturn value
+\t}
+\trunes := []rune(value)
+\treturn string(runes[:width-1]) + "…"
+}
+func joinCapabilities(capabilities []providerpkg.Capability) string {
+\tif len(capabilities) == 0 {
+\t\treturn "none"
+\t}
+\tvalues := make([]string, 0, len(capabilities))
+\tfor _, capability := range capabilities {
+\t\tvalues = append(values, string(capability))
+\t}
+\treturn strings.Join(values, ",")
+}
+func emptyFallback(value, fallback string) string {
+\tif strings.TrimSpace(value) == "" {
+\t\treturn fallback
+\t}
+\treturn value
+}
+func joinStrings(values []string) string {
+\tif len(values) == 0 {
+\t\treturn "none"
+\t}
+\treturn strings.Join(values, ",")
+}
+func minInt(left, right int) int {
+\tif left < right {
+\t\treturn left
+\t}
+\treturn right
+}
+func maxInt(left, right int) int {
+\tif left > right {
+\t\treturn left
+\t}
+\treturn right
+}
