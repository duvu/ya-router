++func sampleTUISnapshot() tuiSnapshot {
++\tnow := time.Date(2026, 7, 16, 1, 2, 3, 0, time.UTC)
++\treturn tuiSnapshot{
++\t\tmeta: controlpkg.MetaResponse{
++\t\t\tServiceVersion: "test-build", DeploymentMode: "local", ConfigRevision: 12,
++\t\t},
++\t\tproviders: []controlpkg.ProviderResource{
++\t\t\t{
++\t\t\t\tDescriptor: providerpkg.Descriptor{ID: providerpkg.Copilot, Name: "GitHub Copilot"},
++\t\t\t\tEnabled:    true, Generation: 7,
++\t\t\t\tEffectiveCapabilities: []providerpkg.Capability{providerpkg.CapabilityChat},
++\t\t\t\tHealth:                providerpkg.HealthRecord{ProviderID: providerpkg.Copilot, State: providerpkg.StateReady},
++\t\t\t},
++\t\t\t{
++\t\t\t\tDescriptor: providerpkg.Descriptor{ID: providerpkg.Codex, Name: "OpenAI Codex"},
++\t\t\t\tEnabled:    false,
++\t\t\t\tHealth:     providerpkg.HealthRecord{ProviderID: providerpkg.Codex, State: providerpkg.StateDisabled},
++\t\t\t},
++\t\t},
++\t\taccounts: []controlpkg.AccountResource{{
