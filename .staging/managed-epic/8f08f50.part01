++func TestTUIKeyboardNavigationAndExit(t *testing.T) {
++\tmodel := newTUIModel(fakeTUIClient{})
++\tupdated, _ := model.Update(tea.KeyMsg{Runes: []rune{'l'}})
++\tmodel = updated.(tuiModel)
++\tif model.tab != 1 {
++\t\tt.Fatalf("right navigation selected tab %d", model.tab)
++\t}
++\tupdated, _ = model.Update(tea.KeyMsg{Runes: []rune{'h'}})
++\tmodel = updated.(tuiModel)
++\tif model.tab != 0 {
++\t\tt.Fatalf("left navigation selected tab %d", model.tab)
++\t}
++\tupdated, command := model.Update(tea.KeyMsg{Runes: []rune{'q'}})
++\tif command == nil || updated.(tuiModel).tab != 0 {
++\t\tt.Fatal("quit did not return a command")
++\t}
++}
