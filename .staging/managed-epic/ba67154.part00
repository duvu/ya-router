 }
diff --git a/internal/control/mutations.go b/internal/control/mutations.go
new file mode 100644
index 0000000..dc38bad
--- /dev/null
+++ b/internal/control/mutations.go
@@ -0,0 +1,241 @@
+package control
+
+import (
+	"context"
+	"encoding/json"
+	"errors"
+	"io"
+	"net/http"
+	"strconv"
+	"strings"
+
+	configschema "github.com/duvu/ya-router/internal/config"
+	statepkg "github.com/duvu/ya-router/internal/state"
+)
+
+type MutationResult struct {
+	Revision        uint64   `json:"revision"`
+	Digest          string   `json:"digest"`
+	EffectiveDigest string   `json:"effective_digest"`
+	ChangedPaths    []string `json:"changed_paths,omitempty"`
+	RestartRequired []string `json:"restart_required,omitempty"`
+	DrainCompleted  bool     `json:"drain_completed"`
+	DrainTimedOut   bool     `json:"drain_timed_out"`
+}
+
+type ProviderPatch struct {
+	Enabled       *bool     `json:"enabled,omitempty"`
+	AllowedModels *[]string `json:"allowed_models,omitempty"`
+}
+
+type AccountPatch struct {
+	Enabled  *bool   `json:"enabled,omitempty"`
+	Label    *string `json:"label,omitempty"`
+	Priority *int    `json:"priority,omitempty"`
+}
+
+type RoutingPatch struct {
+	DefaultModel    *string                                `json:"default_model,omitempty"`
+	DefaultProvider *string                                `json:"default_provider,omitempty"`
+	ModelMap        *map[string]configschema.ModelMapEntry `json:"model_map,omitempty"`
+}
+
+type MutationBackend interface {
+	ValidateConfig(context.Context, *configschema.Config) (statepkg.Preview, error)
+	ApplyConfig(context.Context, uint64, *configschema.Config, string) (MutationResult, error)
+	RollbackConfig(context.Context, uint64, string) (MutationResult, error)
+	PatchProvider(context.Context, uint64, string, ProviderPatch, string) (MutationResult, error)
+	PatchAccount(context.Context, uint64, string, string, AccountPatch, string) (MutationResult, error)
+	DeleteAccount(context.Context, uint64, string, string, string) (MutationResult, error)
+	PatchRouting(context.Context, uint64, RoutingPatch, string) (MutationResult, error)
+}
+
+func RegisterMutationRoutes(api *API, backend MutationBackend) {
+	if backend == nil {
+		return
+	}
+	api.Handle(http.MethodPost, "/control/v1/config:validate", RoleAdmin, true, http.HandlerFunc(func(writer http.ResponseWriter, request *http.Request) {
+		var input struct {
+			Desired *configschema.Config `json:"desired"`
+		}
+		if err := decodeMutationJSON(request, &input); err != nil || input.Desired == nil {
+			writeError(writer, request, http.StatusBadRequest, "invalid_config_candidate", "A desired configuration is required.", false, nil)
+			return
+		}
+		preview, err := backend.ValidateConfig(request.Context(), input.Desired)
+		if err != nil {
+			writeMutationError(writer, request, err)
+			return
+		}
+		writeJSON(writer, http.StatusOK, preview)
+	}))
+	api.Handle(http.MethodPatch, "/control/v1/config", RoleAdmin, true, http.HandlerFunc(func(writer http.ResponseWriter, request *http.Request) {
+		var input struct {
+			ExpectedRevision uint64               `json:"expected_revision"`
+			Desired          *configschema.Config `json:"desired"`
+		}
+		if err := decodeMutationJSON(request, &input); err != nil || input.Desired == nil {
+			writeError(writer, request, http.StatusBadRequest, "invalid_config_candidate", "A desired configuration is required.", false, nil)
+			return
+		}
+		expected, err := expectedRevision(request, input.ExpectedRevision)
+		if err != nil {
+			writeError(writer, request, http.StatusPreconditionRequired, "expected_revision_required", "If-Match or expected_revision is required.", false, nil)
+			return
+		}
+		identity, _ := IdentityFromContext(request.Context())
+		result, err := backend.ApplyConfig(request.Context(), expected, input.Desired, identity.Subject)
+		if err != nil {
+			writeMutationError(writer, request, err)
+			return
+		}
+		writeJSON(writer, http.StatusOK, result)
+	}))
+	api.Handle(http.MethodPost, "/control/v1/config:rollback", RoleAdmin, true, http.HandlerFunc(func(writer http.ResponseWriter, request *http.Request) {
+		var input struct {
+			ExpectedRevision uint64 `json:"expected_revision"`
+		}
+		_ = decodeMutationJSON(request, &input)
+		expected, err := expectedRevision(request, input.ExpectedRevision)
+		if err != nil {
+			writeError(writer, request, http.StatusPreconditionRequired, "expected_revision_required", "If-Match or expected_revision is required.", false, nil)
+			return
+		}
+		identity, _ := IdentityFromContext(request.Context())
+		result, err := backend.RollbackConfig(request.Context(), expected, identity.Subject)
+		if err != nil {
+			writeMutationError(writer, request, err)
+			return
+		}
+		writeJSON(writer, http.StatusOK, result)
+	}))
+	api.HandlePrefix(http.MethodPatch, "/control/v1/providers/", RoleOperator, true, http.HandlerFunc(func(writer http.ResponseWriter, request *http.Request) {
+		tail := pathTail(request.URL.Path, "/control/v1/providers/")
+		parts := strings.Split(tail, "/")
+		identity, _ := IdentityFromContext(request.Context())
+		var result MutationResult
+		var err error
+		switch {
+		case len(parts) == 1 && parts[0] != "":
+			var envelope struct {
+				ExpectedRevision uint64    `json:"expected_revision"`
+				Enabled          *bool     `json:"enabled,omitempty"`
+				AllowedModels    *[]string `json:"allowed_models,omitempty"`
+			}
+			if err := decodeMutationJSON(request, &envelope); err != nil {
+				writeError(writer, request, http.StatusBadRequest, "invalid_mutation", "The provider mutation request is invalid.", false, nil)
+				return
+			}
+			expected, revisionErr := expectedRevision(request, envelope.ExpectedRevision)
+			if revisionErr != nil {
+				writeError(writer, request, http.StatusPreconditionRequired, "expected_revision_required", "If-Match or expected_revision is required.", false, nil)
+				return
+			}
+			result, err = backend.PatchProvider(request.Context(), expected, parts[0], ProviderPatch{Enabled: envelope.Enabled, AllowedModels: envelope.AllowedModels}, identity.Subject)
+		case len(parts) == 3 && parts[1] == "accounts":
+			var envelope struct {
+				ExpectedRevision uint64  `json:"expected_revision"`
+				Enabled          *bool   `json:"enabled,omitempty"`
+				Label            *string `json:"label,omitempty"`
+				Priority         *int    `json:"priority,omitempty"`
+			}
+			if err := decodeMutationJSON(request, &envelope); err != nil {
+				writeError(writer, request, http.StatusBadRequest, "invalid_mutation", "The account mutation request is invalid.", false, nil)
+				return
+			}
+			expected, revisionErr := expectedRevision(request, envelope.ExpectedRevision)
+			if revisionErr != nil {
+				writeError(writer, request, http.StatusPreconditionRequired, "expected_revision_required", "If-Match or expected_revision is required.", false, nil)
+				return
+			}
+			result, err = backend.PatchAccount(request.Context(), expected, parts[0], parts[2], AccountPatch{Enabled: envelope.Enabled, Label: envelope.Label, Priority: envelope.Priority}, identity.Subject)
+		default:
+			writeError(writer, request, http.StatusNotFound, "control_resource_not_found", "The control resource was not found.", false, nil)
+			return
+		}
+		if err != nil {
+			writeMutationError(writer, request, err)
+			return
+		}
+		writeJSON(writer, http.StatusOK, result)
+	}))
+	api.HandlePrefix(http.MethodDelete, "/control/v1/providers/", RoleAdmin, true, http.HandlerFunc(func(writer http.ResponseWriter, request *http.Request) {
+		tail := pathTail(request.URL.Path, "/control/v1/providers/")
+		parts := strings.Split(tail, "/")
+		if len(parts) != 3 || parts[1] != "accounts" {
+			writeError(writer, request, http.StatusNotFound, "control_resource_not_found", "The control resource was not found.", false, nil)
+			return
+		}
+		expected, err := expectedRevision(request, 0)
+		if err != nil {
+			writeError(writer, request, http.StatusPreconditionRequired, "expected_revision_required", "If-Match is required.", false, nil)
+			return
+		}
+		identity, _ := IdentityFromContext(request.Context())
+		result, err := backend.DeleteAccount(request.Context(), expected, parts[0], parts[2], identity.Subject)
+		if err != nil {
+			writeMutationError(writer, request, err)
+			return
+		}
+		writeJSON(writer, http.StatusOK, result)
+	}))
+	api.Handle(http.MethodPatch, "/control/v1/routing", RoleAdmin, true, http.HandlerFunc(func(writer http.ResponseWriter, request *http.Request) {
+		var envelope struct {
+			ExpectedRevision uint64 `json:"expected_revision"`
+			RoutingPatch
+		}
+		if err := decodeMutationJSON(request, &envelope); err != nil {
+			writeError(writer, request, http.StatusBadRequest, "invalid_mutation", "The routing mutation is invalid.", false, nil)
+			return
+		}
+		expected, err := expectedRevision(request, envelope.ExpectedRevision)
+		if err != nil {
+			writeError(writer, request, http.StatusPreconditionRequired, "expected_revision_required", "If-Match or expected_revision is required.", false, nil)
+			return
+		}
+		identity, _ := IdentityFromContext(request.Context())
+		result, err := backend.PatchRouting(request.Context(), expected, envelope.RoutingPatch, identity.Subject)
+		if err != nil {
+			writeMutationError(writer, request, err)
+			return
+		}
+		writeJSON(writer, http.StatusOK, result)
+	}))
+}
+
+func decodeMutationJSON(request *http.Request, destination any) error {
+	if request.Body == nil {
+		return io.EOF
+	}
+	decoder := json.NewDecoder(io.LimitReader(request.Body, 2<<20))
+	decoder.DisallowUnknownFields()
+	return decoder.Decode(destination)
+}
+func expectedRevision(request *http.Request, body uint64) (uint64, error) {
+	if body > 0 {
+		return body, nil
+	}
