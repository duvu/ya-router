+	value := strings.Trim(strings.TrimSpace(request.Header.Get("If-Match")), "\"")
+	if value == "" {
+		return 0, errors.New("missing revision")
+	}
+	return strconv.ParseUint(value, 10, 64)
+}
+func writeMutationError(writer http.ResponseWriter, request *http.Request, err error) {
+	var conflict *statepkg.ConflictError
+	switch {
+	case errors.As(err, &conflict):
+		writeError(writer, request, http.StatusConflict, "config_revision_conflict", "Configuration changed; reload before applying.", false, map[string]any{"expected_revision": conflict.Expected, "current_revision": conflict.Current})
+	case strings.Contains(err.Error(), "not found"):
+		writeError(writer, request, http.StatusNotFound, "mutation_target_not_found", "The mutation target was not found.", false, nil)
+	default:
+		writeError(writer, request, http.StatusUnprocessableEntity, "configuration_rejected", "The configuration change was rejected.", false, nil)
+	}
+}
+
+func pathTail(path, prefix string) string {
+	if !strings.HasPrefix(path, prefix) {
+		return ""
+	}
+	return strings.TrimPrefix(path, prefix)
+}
