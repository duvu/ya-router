diff --git a/src/mutation_controller.go b/src/mutation_controller.go
new file mode 100644
index 0000000..f9edb82
--- /dev/null
+++ b/src/mutation_controller.go
@@ -0,0 +1,475 @@
+package yarouter
+
+import (
+	"context"
+	"fmt"
+	"os"
+	"sort"
+	"strings"
+
+	configschema "github.com/duvu/ya-router/internal/config"
+	controlpkg "github.com/duvu/ya-router/internal/control"
+	providerpkg "github.com/duvu/ya-router/internal/provider"
+	statepkg "github.com/duvu/ya-router/internal/state"
+)
+
+// managedMutationController is the only Control API path allowed to change
+// desired/effective configuration. It never invokes an OS service manager or
+// shell and never mutates a provider instance serving requests in place.
+type managedMutationController struct {
+	providers *providerpkg.Manager
+	secrets   *managedSecretStore
+}
+
+func newManagedMutationController(providers *providerpkg.Manager, secrets *managedSecretStore) *managedMutationController {
+	return &managedMutationController{providers: providers, secrets: secrets}
+}
+
+func (controller *managedMutationController) ValidateConfig(ctx context.Context, desired *Config) (statepkg.Preview, error) {
+	state := currentConfigState()
+	if state == nil {
+		return statepkg.Preview{}, fmt.Errorf("managed configuration state is unavailable")
+	}
+	candidate := configschema.Clone(desired)
+	if err := validateManagementCandidate(candidate); err != nil {
+		return statepkg.Preview{}, err
+	}
+	effective := hotEffectiveConfig(state.Snapshot().Effective, candidate)
+	if _, err := materializeManagedSecrets(ctx, effective, controller.secretStore()); err != nil {
+		return statepkg.Preview{}, err
+	}
+	return state.Validate(candidate, effective)
+}
+
+func (controller *managedMutationController) ApplyConfig(ctx context.Context, expected uint64, desired *Config, actor string) (controlpkg.MutationResult, error) {
+	return controller.apply(ctx, expected, desired, actor)
+}
+
+func (controller *managedMutationController) RollbackConfig(ctx context.Context, expected uint64, actor string) (controlpkg.MutationResult, error) {
+	managementMutationMu.Lock()
+	defer managementMutationMu.Unlock()
+	state := currentConfigState()
+	if state == nil {
+		return controlpkg.MutationResult{}, fmt.Errorf("managed configuration state is unavailable")
+	}
+	before := state.Snapshot()
+	if expected != before.Revision {
+		return controlpkg.MutationResult{}, &statepkg.ConflictError{Expected: expected, Current: before.Revision}
+	}
+	rolled, err := state.Rollback(expected, actor)
+	if err != nil {
+		return controlpkg.MutationResult{}, err
+	}
+	effectiveRefs := hotEffectiveConfig(before.Effective, rolled.Desired)
+	materialized, err := materializeManagedSecrets(ctx, effectiveRefs, controller.secretStore())
+	if err != nil {
+		return controlpkg.MutationResult{}, fmt.Errorf("materialize rollback configuration: %w", err)
+	}
+	drain, err := controller.providers.Reconcile(ctx, desiredProviders(materialized))
+	if err != nil {
+		// Desired rollback is durable but cannot safely become effective. Retain the
+		// previous effective snapshot and surface restart-required state.
+		return mutationResult(rolled, statepkg.Preview{ChangedPaths: rolled.RestartRequired}, providerpkg.DrainReport{}), fmt.Errorf("apply rollback runtime: %w", err)
+	}
+	final, err := state.SetEffective(rolled.Revision, effectiveRefs, actor)
+	if err != nil {
+		previous, previousErr := materializeManagedSecrets(context.Background(), before.Effective, controller.secretStore())
+		if previousErr == nil {
+			_, _ = controller.providers.Reconcile(context.Background(), desiredProviders(previous))
+		}
+		return controlpkg.MutationResult{}, err
+	}
+	preview, _ := state.Validate(final.Desired, final.Effective)
+	return mutationResult(final, preview, drain), nil
+}
+
+func (controller *managedMutationController) PatchProvider(ctx context.Context, expected uint64, provider string, patch controlpkg.ProviderPatch, actor string) (controlpkg.MutationResult, error) {
+	candidate, err := controller.currentCandidate(expected)
+	if err != nil {
+		return controlpkg.MutationResult{}, err
+	}
+	switch providerpkg.ID(provider) {
+	case providerpkg.Copilot:
+		if patch.Enabled != nil {
+			candidate.Providers.Copilot.Enabled = *patch.Enabled
+		}
+		if patch.AllowedModels != nil {
+			candidate.Providers.Copilot.AllowedModels = cleanModelList(*patch.AllowedModels)
+		}
+	case providerpkg.Codex:
+		if patch.Enabled != nil {
+			candidate.Providers.Codex.Enabled = *patch.Enabled
+		}
+		if patch.AllowedModels != nil {
+			candidate.Providers.Codex.AllowedModels = cleanModelList(*patch.AllowedModels)
+		}
+	case providerpkg.Kilo:
+		if patch.Enabled != nil {
+			candidate.Providers.Kilo.Enabled = *patch.Enabled
+		}
+		if patch.AllowedModels != nil {
+			candidate.Providers.Kilo.AllowedModels = cleanModelList(*patch.AllowedModels)
+		}
+	default:
+		return controlpkg.MutationResult{}, fmt.Errorf("provider %q not found", provider)
+	}
+	return controller.apply(ctx, expected, candidate, actor)
+}
+
+func (controller *managedMutationController) PatchAccount(ctx context.Context, expected uint64, provider, account string, patch controlpkg.AccountPatch, actor string) (controlpkg.MutationResult, error) {
+	candidate, err := controller.currentCandidate(expected)
+	if err != nil {
+		return controlpkg.MutationResult{}, err
+	}
+	switch providerpkg.ID(provider) {
+	case providerpkg.Copilot:
+		index := findCopilotAccount(candidate.Providers.Copilot.Accounts, account)
+		if index < 0 {
+			return controlpkg.MutationResult{}, fmt.Errorf("account %q not found", account)
+		}
+		if patch.Enabled != nil {
+			candidate.Providers.Copilot.Accounts[index].Disabled = !*patch.Enabled
+		}
+		if patch.Label != nil {
+			candidate.Providers.Copilot.Accounts[index].Label = strings.TrimSpace(*patch.Label)
+		}
+		if patch.Priority != nil {
+			candidate.Providers.Copilot.Accounts = moveCopilotAccount(candidate.Providers.Copilot.Accounts, index, *patch.Priority)
+		}
+	case providerpkg.Codex:
+		index := findCodexAccount(candidate.Providers.Codex.Accounts, account)
+		if index < 0 {
+			return controlpkg.MutationResult{}, fmt.Errorf("account %q not found", account)
+		}
+		if patch.Enabled != nil {
+			candidate.Providers.Codex.Accounts[index].Disabled = !*patch.Enabled
+		}
+		if patch.Label != nil {
+			candidate.Providers.Codex.Accounts[index].Label = strings.TrimSpace(*patch.Label)
+		}
+		if patch.Priority != nil {
+			candidate.Providers.Codex.Accounts = moveCodexAccount(candidate.Providers.Codex.Accounts, index, *patch.Priority)
+		}
+	default:
+		return controlpkg.MutationResult{}, fmt.Errorf("provider %q does not expose managed accounts", provider)
+	}
+	return controller.apply(ctx, expected, candidate, actor)
+}
+
+func (controller *managedMutationController) DeleteAccount(ctx context.Context, expected uint64, provider, account, actor string) (controlpkg.MutationResult, error) {
+	candidate, err := controller.currentCandidate(expected)
+	if err != nil {
+		return controlpkg.MutationResult{}, err
+	}
+	var refs []*SecretReference
+	switch providerpkg.ID(provider) {
+	case providerpkg.Copilot:
+		index := findCopilotAccount(candidate.Providers.Copilot.Accounts, account)
+		if index < 0 {
+			return controlpkg.MutationResult{}, fmt.Errorf("account %q not found", account)
+		}
+		auth := candidate.Providers.Copilot.Accounts[index].Auth
+		refs = append(refs, auth.GitHubTokenRef, auth.CopilotTokenRef)
+		candidate.Providers.Copilot.Accounts = append(candidate.Providers.Copilot.Accounts[:index], candidate.Providers.Copilot.Accounts[index+1:]...)
+	case providerpkg.Codex:
+		index := findCodexAccount(candidate.Providers.Codex.Accounts, account)
+		if index < 0 {
+			return controlpkg.MutationResult{}, fmt.Errorf("account %q not found", account)
+		}
+		auth := candidate.Providers.Codex.Accounts[index].Auth
+		refs = append(refs, auth.APIKeyRef, auth.AccessTokenRef, auth.RefreshTokenRef)
+		candidate.Providers.Codex.Accounts = append(candidate.Providers.Codex.Accounts[:index], candidate.Providers.Codex.Accounts[index+1:]...)
+	default:
+		return controlpkg.MutationResult{}, fmt.Errorf("provider %q does not expose removable accounts", provider)
+	}
+	result, err := controller.apply(ctx, expected, candidate, actor)
+	if err != nil {
+		return controlpkg.MutationResult{}, err
+	}
+	for _, ref := range refs {
+		if ref != nil && !ref.ReadOnly {
+			_ = controller.secretStore().Delete(context.Background(), ref)
+		}
+	}
+	return result, nil
+}
+
+func (controller *managedMutationController) PatchRouting(ctx context.Context, expected uint64, patch controlpkg.RoutingPatch, actor string) (controlpkg.MutationResult, error) {
+	candidate, err := controller.currentCandidate(expected)
+	if err != nil {
+		return controlpkg.MutationResult{}, err
+	}
+	if patch.DefaultModel != nil {
+		candidate.Routing.DefaultModel = strings.TrimSpace(*patch.DefaultModel)
+	}
+	if patch.DefaultProvider != nil {
+		candidate.Routing.DefaultProvider = strings.TrimSpace(*patch.DefaultProvider)
+	}
+	if patch.ModelMap != nil {
+		candidate.Routing.ModelMap = cloneMutationModelMap(*patch.ModelMap)
+	}
+	return controller.apply(ctx, expected, candidate, actor)
+}
+
+func (controller *managedMutationController) currentCandidate(expected uint64) (*Config, error) {
+	state := currentConfigState()
+	if state == nil {
+		return nil, fmt.Errorf("managed configuration state is unavailable")
+	}
+	snapshot := state.Snapshot()
+	if snapshot.Revision != expected {
+		return nil, &statepkg.ConflictError{Expected: expected, Current: snapshot.Revision}
+	}
+	return configschema.Clone(snapshot.Desired), nil
+}
+
+func (controller *managedMutationController) apply(ctx context.Context, expected uint64, desired *Config, actor string) (controlpkg.MutationResult, error) {
+	managementMutationMu.Lock()
+	defer managementMutationMu.Unlock()
