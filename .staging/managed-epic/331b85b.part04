+		select {
+		case <-ctx.Done():
+			timer.Stop()
+			return CodexAuthState{}, ctx.Err()
+		case <-timer.C:
+		}
+		candidate, status, pollErr := pollCodexDeviceTokenContext(ctx, apiBase, flow.DeviceAuthID, flow.UserCode)
 		if pollErr != nil {
-			return pollErr
+			return CodexAuthState{}, pollErr
 		}
 		if status == http.StatusForbidden || status == http.StatusNotFound {
 			continue
 		}
 		if status != http.StatusOK {
-			return fmt.Errorf("device authorization poll returned status %d", status)
+			return CodexAuthState{}, fmt.Errorf("device authorization poll returned status %d", status)
 		}
 		deviceToken = *candidate
 		break
 	}
 	if deviceToken.AuthorizationCode == "" || deviceToken.CodeVerifier == "" {
-		return errors.New("device authorization timed out")
+		return CodexAuthState{}, errors.New("device authorization timed out")
