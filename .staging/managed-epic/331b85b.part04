+func completeCodexDeviceFlow(ctx context.Context, flow codexDeviceFlow) (CodexAuthState, error) {
+	apiBase := codexAuthIssuer + "/api/accounts"
+	deadline := flow.ExpiresAt
+	if deadline.IsZero() {
+		deadline = time.Now().Add(codexDeviceAuthorizationTTL)
+	}
 	var deviceToken codexDeviceTokenResp
 	for time.Now().Before(deadline) {
-		time.Sleep(time.Duration(interval) * time.Second)
