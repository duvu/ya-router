+func (codexManagedAuthAdapter) Anonymous(context.Context) (managedCredential, error) {
+	return managedCredential{}, fmt.Errorf("Codex does not support anonymous authentication")
+}
+
+type kiloManagedAuthAdapter struct{}
+
+func (kiloManagedAuthAdapter) BeginDevice(context.Context) (authChallenge, error) {
+	return authChallenge{}, fmt.Errorf("Kilo does not support device-code authentication")
+}
+func (kiloManagedAuthAdapter) FromSecret(_ context.Context, mode string, value []byte) (managedCredential, error) {
+	if mode != "api_key" {
+		return managedCredential{}, fmt.Errorf("Kilo supports api_key or anonymous")
+	}
+	return managedCredential{KiloKey: append([]byte(nil), value...)}, nil
+}
+func (kiloManagedAuthAdapter) Anonymous(context.Context) (managedCredential, error) {
+	return managedCredential{Anonymous: true}, nil
+}
+
+func (controller *managedAuthController) RotateSecretKey(ctx context.Context, encoded []byte) error {
+	key, err := secretpkg.ParseKey(string(encoded))
+	if err != nil {
+		return err
+	}
+	defer zeroSecretBytes(key)
+	return controller.managedSecrets.rotateLocalKey(ctx, key)
+}
diff --git a/src/auth_controller_test.go b/src/auth_controller_test.go
new file mode 100644
index 0000000..e3c4e2b
--- /dev/null
+++ b/src/auth_controller_test.go
@@ -0,0 +1,145 @@
+package yarouter
+
+import (
+	"bytes"
+	"context"
+	"encoding/json"
+	"path/filepath"
+	"strings"
+	"testing"
+	"time"
+
+	controlpkg "github.com/duvu/ya-router/internal/control"
+	operationpkg "github.com/duvu/ya-router/internal/operation"
+	runtimepkg "github.com/duvu/ya-router/internal/runtime"
+	secretpkg "github.com/duvu/ya-router/internal/secret"
+)
+
+type fakeAuthAdapter struct {
+	challenge  authChallenge
+	credential managedCredential
+}
+
+func (adapter fakeAuthAdapter) BeginDevice(context.Context) (authChallenge, error) {
+	return adapter.challenge, nil
+}
+func (adapter fakeAuthAdapter) FromSecret(context.Context, string, []byte) (managedCredential, error) {
+	return adapter.credential, nil
+}
+func (adapter fakeAuthAdapter) Anonymous(context.Context) (managedCredential, error) {
+	return adapter.credential, nil
+}
+
+func newAuthControllerTest(t *testing.T) (*managedAuthController, func()) {
+	t.Helper()
+	directory := t.TempDir()
+	oldOverride := configPathOverride
+	configPathOverride = filepath.Join(directory, "config.json")
+	release, err := acquireManagedConfigState("auth-test")
+	if err != nil {
+		t.Fatal(err)
+	}
+	config, err := loadConfig()
+	if err != nil {
+		t.Fatal(err)
+	}
+	runtimeManager, err := runtimepkg.NewManager(config)
+	if err != nil {
+		t.Fatal(err)
+	}
+	providers, err := newProviderManager(config, runtimeManager)
+	if err != nil {
+		t.Fatal(err)
+	}
+	operations, err := operationpkg.OpenManager(operationpkg.Options{Path: filepath.Join(directory, "operations.json")})
+	if err != nil {
+		t.Fatal(err)
+	}
+	secrets, err := secretpkg.OpenFile(filepath.Join(directory, "secrets.json"), bytes.Repeat([]byte{7}, 32))
+	if err != nil {
+		t.Fatal(err)
+	}
+	controller := newManagedAuthController(operations, &managedSecretStore{store: secrets}, providers)
+	cleanup := func() {
+		_ = operations.Close(context.Background())
+		_, _ = providers.Reconcile(context.Background(), nil)
+		_ = runtimeManager.Close(context.Background())
+		_ = release()
+		configPathOverride = oldOverride
+	}
+	return controller, cleanup
+}
+
+func TestManagedAuthAPIKeyIsWriteOnlyAndPersistsReference(t *testing.T) {
+	controller, cleanup := newAuthControllerTest(t)
+	defer cleanup()
+	auth := CodexAuthState{Mode: "api_key", APIKey: "top-secret"}
+	controller.adapters[string(ProviderCodex)] = fakeAuthAdapter{credential: managedCredential{Codex: &auth}}
+	request := controlpkg.AuthSessionStart{Provider: string(ProviderCodex), Account: "work", Mode: "api_key", Owner: "operator", IdempotencyKey: "auth-one", RequestDigest: "digest", Secret: []byte("top-secret")}
+	view, created, err := controller.StartAuthSession(context.Background(), request)
+	if err != nil || !created {
+		t.Fatalf("start: %+v %v", view, err)
+	}
+	operation := waitOperationState(t, controller.operations, view.Operation.ID, operationpkg.StateSucceeded)
+	payload, _ := json.Marshal(operation)
+	if strings.Contains(string(payload), "top-secret") {
+		t.Fatalf("operation leaked secret: %s", payload)
+	}
+	snapshot := currentConfigState().Snapshot()
+	var found bool
+	for _, account := range snapshot.Desired.Providers.Codex.Accounts {
+		if account.Label == "work" {
+			found = account.Auth.APIKeyRef != nil && account.Auth.APIKey == ""
+		}
+	}
+	if !found {
+		t.Fatalf("managed API key reference was not persisted: %+v", snapshot.Desired.Providers.Codex.Accounts)
+	}
+}
+
+func TestEnvironmentCredentialCannotBeShadowed(t *testing.T) {
+	controller, cleanup := newAuthControllerTest(t)
+	defer cleanup()
+	t.Setenv("OPENAI_API_KEY", "environment-secret")
+	_, _, err := controller.StartAuthSession(context.Background(), controlpkg.AuthSessionStart{Provider: string(ProviderCodex), Mode: "api_key", Owner: "operator", Secret: []byte("different")})
+	if err == nil || !strings.Contains(err.Error(), "read-only") {
+		t.Fatalf("expected read-only precedence error, got %v", err)
+	}
+}
+
+func TestDeviceOperationSurvivesRequestCancellation(t *testing.T) {
+	controller, cleanup := newAuthControllerTest(t)
+	defer cleanup()
+	complete := make(chan struct{})
+	auth := CodexAuthState{Mode: "chatgpt", AccessToken: "access", RefreshToken: "refresh", ExpiresAt: time.Now().Add(time.Hour).Unix()}
+	controller.adapters[string(ProviderCodex)] = fakeAuthAdapter{challenge: authChallenge{VerificationURI: "https://example.test/device", UserCode: "ABCD-EFGH", ExpiresAt: time.Now().Add(time.Minute), Complete: func(context.Context) (managedCredential, error) {
+		<-complete
+		return managedCredential{Codex: &auth}, nil
+	}}}
+	requestContext, cancel := context.WithCancel(context.Background())
+	view, _, err := controller.StartAuthSession(requestContext, controlpkg.AuthSessionStart{Provider: string(ProviderCodex), Mode: "device_code", Owner: "operator"})
+	if err != nil {
+		t.Fatal(err)
+	}
+	cancel()
+	close(complete)
+	operation := waitOperationState(t, controller.operations, view.Operation.ID, operationpkg.StateSucceeded)
+	if operation.State != operationpkg.StateSucceeded {
+		t.Fatalf("operation was cancelled with request: %+v", operation)
+	}
+}
+
+func waitOperationState(t *testing.T, store *operationpkg.Manager, id string, want operationpkg.State) operationpkg.Record {
+	t.Helper()
+	deadline := time.Now().Add(3 * time.Second)
+	for time.Now().Before(deadline) {
+		operation, err := store.Get(id)
+		if err == nil && operation.State == want {
+			return operation
+		}
+		time.Sleep(10 * time.Millisecond)
+	}
+	operation, _ := store.Get(id)
+	t.Fatalf("operation did not reach %s: %+v", want, operation)
+	return operationpkg.Record{}
+}
