diff --git a/src/secret_runtime.go b/src/secret_runtime.go
new file mode 100644
index 0000000..6b050fc
--- /dev/null
+++ b/src/secret_runtime.go
@@ -0,0 +1,244 @@
+package yarouter
+
+import (
+	"context"
+	"crypto/rand"
+	"fmt"
+	"os"
+	"path/filepath"
+	"strings"
+
+	configschema "github.com/duvu/ya-router/internal/config"
+	secretpkg "github.com/duvu/ya-router/internal/secret"
+)
+
+const secretStoreKeyEnv = "YA_ROUTER_SECRET_STORE_KEY"
+
+type managedSecretStore struct {
+	store   *secretpkg.FileStore
+	keyPath string
+	source  string
+}
+
+func openManagedSecretStore(configPath string) (*managedSecretStore, error) {
+	directory := filepath.Dir(configPath)
+	var key []byte
+	source := "local_key_file"
+	keyPath := filepath.Join(directory, "secret-store.key")
+	if value := strings.TrimSpace(os.Getenv(secretStoreKeyEnv)); value != "" {
+		parsed, err := secretpkg.ParseKey(value)
+		if err != nil {
+			return nil, fmt.Errorf("%s: %w", secretStoreKeyEnv, err)
+		}
+		key = parsed
+		source = "environment_key"
+		keyPath = ""
+	} else {
+		data, err := os.ReadFile(keyPath)
+		if err != nil {
+			if !os.IsNotExist(err) {
+				return nil, fmt.Errorf("read secret-store key: %w", err)
+			}
+			key = make([]byte, 32)
+			if _, err := rand.Read(key); err != nil {
+				return nil, err
+			}
+			if err := writePrivateFile(keyPath, key); err != nil {
+				return nil, err
+			}
+		} else {
+			key = data
+		}
+		if len(key) != 32 {
+			return nil, fmt.Errorf("secret-store key file must contain exactly 32 bytes")
+		}
+	}
+	store, err := secretpkg.OpenFile(filepath.Join(directory, "secrets.json"), key)
+	zeroSecretBytes(key)
+	if err != nil {
+		return nil, err
+	}
+	return &managedSecretStore{store: store, keyPath: keyPath, source: source}, nil
+}
+
+func writePrivateFile(path string, value []byte) error {
