+
+func mergeManagedCopilotAuth(destination *CopilotAuthState, source CopilotAuthState) error {
+	if destination == nil {
+		return nil
+	}
+	if destination.GitHubTokenRef == nil && destination.CopilotTokenRef == nil {
+		*destination = source
+		return nil
+	}
+	managed, err := openManagedSecretStoreForPersistence()
+	if err != nil {
+		return err
+	}
+	newGitHub, newCopilot := destination.GitHubTokenRef, destination.CopilotTokenRef
+	created := make([]*SecretReference, 0, 2)
+	if source.GitHubToken != "" {
+		value := []byte(source.GitHubToken)
+		defer zeroSecretBytes(value)
+		newGitHub, err = managed.store.Put(context.Background(), "copilot/runtime/github-token", value)
+		if err != nil {
+			return err
+		}
+		created = append(created, newGitHub)
+	}
+	if source.CopilotToken != "" {
+		value := []byte(source.CopilotToken)
+		defer zeroSecretBytes(value)
+		newCopilot, err = managed.store.Put(context.Background(), "copilot/runtime/copilot-token", value)
+		if err != nil {
+			for _, ref := range created {
+				_ = managed.store.Delete(context.Background(), ref)
+			}
+			return err
+		}
+		created = append(created, newCopilot)
+	}
+	old := []*SecretReference{destination.GitHubTokenRef, destination.CopilotTokenRef}
+	*destination = CopilotAuthState{Mode: source.Mode, GitHubTokenRef: newGitHub, CopilotTokenRef: newCopilot, ExpiresAt: source.ExpiresAt, RefreshIn: source.RefreshIn}
+	newIDs := map[string]struct{}{}
+	for _, ref := range []*SecretReference{newGitHub, newCopilot} {
+		if ref != nil {
+			newIDs[ref.ID] = struct{}{}
+		}
+	}
+	for _, ref := range old {
+		if ref != nil {
+			if _, keep := newIDs[ref.ID]; !keep {
+				_ = managed.store.Delete(context.Background(), ref)
+			}
+		}
+	}
+	return nil
+}
+
+func mergeManagedCodexAuth(destination *CodexAuthState, source CodexAuthState) error {
+	if destination == nil {
+		return nil
+	}
+	if destination.APIKeyRef == nil && destination.AccessTokenRef == nil && destination.RefreshTokenRef == nil {
+		*destination = source
+		return nil
+	}
+	managed, err := openManagedSecretStoreForPersistence()
+	if err != nil {
+		return err
+	}
+	apiRef, accessRef, refreshRef := destination.APIKeyRef, destination.AccessTokenRef, destination.RefreshTokenRef
+	created := make([]*SecretReference, 0, 3)
+	put := func(name, value string, current **SecretReference) error {
+		if value == "" {
+			return nil
+		}
+		bytes := []byte(value)
+		defer zeroSecretBytes(bytes)
+		ref, err := managed.store.Put(context.Background(), name, bytes)
+		if err != nil {
+			return err
+		}
+		*current = ref
+		created = append(created, ref)
+		return nil
+	}
+	if err := put("codex/runtime/api-key", source.APIKey, &apiRef); err != nil {
+		return err
+	}
+	if err := put("codex/runtime/access-token", source.AccessToken, &accessRef); err != nil {
+		for _, ref := range created {
+			_ = managed.store.Delete(context.Background(), ref)
+		}
+		return err
+	}
+	if err := put("codex/runtime/refresh-token", source.RefreshToken, &refreshRef); err != nil {
+		for _, ref := range created {
+			_ = managed.store.Delete(context.Background(), ref)
+		}
+		return err
+	}
+	old := []*SecretReference{destination.APIKeyRef, destination.AccessTokenRef, destination.RefreshTokenRef}
+	*destination = CodexAuthState{Mode: source.Mode, APIKeyRef: apiRef, AccessTokenRef: accessRef, RefreshTokenRef: refreshRef, ExpiresAt: source.ExpiresAt}
+	newIDs := map[string]struct{}{}
+	for _, ref := range []*SecretReference{apiRef, accessRef, refreshRef} {
+		if ref != nil {
+			newIDs[ref.ID] = struct{}{}
+		}
+	}
+	for _, ref := range old {
+		if ref != nil {
+			if _, keep := newIDs[ref.ID]; !keep {
+				_ = managed.store.Delete(context.Background(), ref)
+			}
+		}
+	}
+	return nil
+}
+
+func openManagedSecretStoreForPersistence() (*managedSecretStore, error) {
+	path, err := getConfigPath()
+	if err != nil {
+		return nil, err
+	}
+	return openManagedSecretStore(path)
+}
