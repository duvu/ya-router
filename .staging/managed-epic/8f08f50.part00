diff --git a/src/tui.go b/src/tui.go
new file mode 100644
index 0000000..6546da5
--- /dev/null
+++ b/src/tui.go
@@ -0,0 +1,451 @@
+package yarouter
+
+import (
+	"context"
+	"errors"
+	"fmt"
+	"io"
+	"sort"
+	"strings"
+	"time"
+
+	"github.com/charmbracelet/bubbles/spinner"
+	tea "github.com/charmbracelet/bubbletea"
+	"github.com/charmbracelet/lipgloss"
+
+	clientpkg "github.com/duvu/ya-router/internal/client"
+	controlpkg "github.com/duvu/ya-router/internal/control"
+	providerpkg "github.com/duvu/ya-router/internal/provider"
+)
+
+type tuiAPI interface {
+	Meta(context.Context) (controlpkg.MetaResponse, error)
+	Providers(context.Context) ([]controlpkg.ProviderResource, error)
+	Accounts(context.Context) ([]controlpkg.AccountResource, error)
+	Models(context.Context, bool) (controlpkg.ModelCatalogResponse, error)
+	Configuration(context.Context) (controlpkg.ConfigResource, error)
+	Operations(context.Context) ([]controlpkg.OperationResource, error)
+	Events(context.Context, uint64) (controlpkg.EventPage, error)
+}
+
+type tuiTheme int
+
+const (
+	themeAuto tuiTheme = iota
+	themeLight
+	themeDark
+	themeMonochrome
+)
+
+func (theme tuiTheme) String() string {
+	switch theme {
+	case themeLight:
+		return "light"
+	case themeDark:
+		return "dark"
+	case themeMonochrome:
+		return "monochrome"
+	default:
+		return "auto"
+	}
+}
+
+type tuiSnapshot struct {
+	meta          controlpkg.MetaResponse
+	providers     []controlpkg.ProviderResource
+	accounts      []controlpkg.AccountResource
+	models        controlpkg.ModelCatalogResponse
+	configuration controlpkg.ConfigResource
+	operations    []controlpkg.OperationResource
+	events        controlpkg.EventPage
+	loadedAt      time.Time
+}
+
+type tuiLoadedMsg struct{ snapshot tuiSnapshot }
+type tuiErrorMsg struct{ err error }
+type tuiTickMsg time.Time
+
+type tuiModel struct {
+	client  tuiAPI
+	spinner spinner.Model
+	width   int
+	height  int
+	tab     int
+	theme   tuiTheme
+	loading bool
+	offline bool
+	err     error
+	data    tuiSnapshot
+}
+
+var tuiTabs = []string{"Overview", "Providers", "Accounts", "Models", "Config", "Operations", "Events"}
+
+func newTUIModel(client tuiAPI) tuiModel {
+	return tuiModel{client: client, spinner: spinner.New(), width: 80, height: 24, loading: true}
+}
+
+func (model tuiModel) Init() tea.Cmd {
+	return tea.Batch(model.spinner.Tick, model.loadCmd(false), tuiTickCmd())
+}
+
+func (model tuiModel) Update(message tea.Msg) (tea.Model, tea.Cmd) {
+	switch message := message.(type) {
+	case tea.WindowSizeMsg:
+		model.width = maxInt(32, message.Width)
+		model.height = maxInt(10, message.Height)
+		return model, nil
+	case tea.KeyMsg:
+		switch strings.ToLower(message.String()) {
+		case "q", "ctrl+c":
+			return model, tea.Quit
+		case "tab", "right", "l":
+			model.tab = (model.tab + 1) % len(tuiTabs)
+			return model, nil
+		case "shift+tab", "left", "h":
+			model.tab = (model.tab - 1 + len(tuiTabs)) % len(tuiTabs)
+			return model, nil
+		case "r":
+			model.loading = true
+			return model, model.loadCmd(true)
+		case "t":
+			model.theme = (model.theme + 1) % 4
+			return model, nil
+		case "1", "2", "3", "4", "5", "6", "7":
+			model.tab = int(message.String()[0] - '1')
+			return model, nil
+		}
+	case spinner.TickMsg:
+		var command tea.Cmd
+		model.spinner, command = model.spinner.Update(message)
+		return model, command
+	case tuiLoadedMsg:
+		model.data = message.snapshot
+		model.loading = false
+		model.offline = false
+		model.err = nil
+		return model, nil
+	case tuiErrorMsg:
+		model.loading = false
+		model.offline = true
+		model.err = sanitizeTUIError(message.err)
+		return model, nil
+	case tuiTickMsg:
+		return model, tea.Batch(tuiTickCmd(), model.loadCmd(false))
+	}
+	return model, nil
+}
+
+func (model tuiModel) View() string {
+	styles := tuiStylesFor(model.theme)
+	status := "CONNECTED"
+	if model.offline {
+		status = "OFFLINE"
+	} else if model.loading {
+		status = "REFRESHING"
+	}
+	header := styles.title.Render("ya-router control") + "  " + status + "  theme=" + model.theme.String()
+	if model.loading {
+		header += " " + model.spinner.View()
+	}
+	tabs := make([]string, 0, len(tuiTabs))
+	for index, tab := range tuiTabs {
+		label := fmt.Sprintf("%d:%s", index+1, tab)
+		if index == model.tab {
+			label = styles.active.Render("[" + label + "]")
+		}
+		tabs = append(tabs, label)
+	}
+	body := model.renderTab(styles)
+	if model.err != nil {
+		body = styles.error.Render("Error: "+model.err.Error()) + "\n\n" + body
+	}
+	footer := "Tab/←/→ switch  r reconnect/refresh  t theme  q quit"
+	return strings.Join([]string{
+		fitTUILine(header, model.width), fitTUILine(strings.Join(tabs, "  "), model.width),
+		strings.Repeat("-", minInt(model.width, 120)), body,
+		strings.Repeat("-", minInt(model.width, 120)), fitTUILine(footer, model.width),
+	}, "\n")
+}
+
+func (model tuiModel) renderTab(styles tuiStyles) string {
+	switch model.tab {
+	case 1:
+		return model.renderProviders(styles)
+	case 2:
+		return model.renderAccounts(styles)
+	case 3:
+		return model.renderModels(styles)
+	case 4:
+		return model.renderConfig(styles)
+	case 5:
+		return model.renderOperations(styles)
+	case 6:
+		return model.renderEvents(styles)
+	default:
+		return model.renderOverview(styles)
+	}
+}
+
+func (model tuiModel) renderOverview(styles tuiStyles) string {
+	ready := 0
+	for _, provider := range model.data.providers {
+		if provider.Enabled && provider.Health.State != providerpkg.StateError && provider.Health.State != providerpkg.StateDisabled {
+			ready++
+		}
+	}
+	modelCount := 0
+	for _, catalog := range model.data.models.Catalogs {
+		modelCount += len(catalog.Models)
+	}
+	loaded := "never"
+	if !model.data.loadedAt.IsZero() {
+		loaded = model.data.loadedAt.Format(time.RFC3339)
+	}
+	return strings.Join([]string{
+		styles.section.Render("Service"),
+		fmt.Sprintf("Version: %s", emptyFallback(model.data.meta.ServiceVersion, "unknown")),
+		fmt.Sprintf("Deployment: %s", emptyFallback(model.data.meta.DeploymentMode, "unknown")),
+		fmt.Sprintf("Config revision: %d", model.data.meta.ConfigRevision),
+		fmt.Sprintf("Restart required: %t", model.data.meta.RestartRequired), "",
+		styles.section.Render("Summary"),
+		fmt.Sprintf("Providers ready: %d/%d", ready, len(model.data.providers)),
+		fmt.Sprintf("Accounts: %d", len(model.data.accounts)),
+		fmt.Sprintf("Models: %d", modelCount),
+		fmt.Sprintf("Operations: %d", len(model.data.operations)),
+		fmt.Sprintf("Last refresh: %s", loaded),
+	}, "\n")
+}
+
+func (model tuiModel) renderProviders(styles tuiStyles) string {
+	lines := []string{styles.section.Render("Providers")}
+	for _, provider := range model.data.providers {
+		state := emptyFallback(string(provider.Health.State), "unknown")
+		lines = append(lines, fmt.Sprintf("[%s] %s (%s) generation=%d capabilities=%s", state, provider.Descriptor.Name, provider.Descriptor.ID, provider.Generation, joinCapabilities(provider.EffectiveCapabilities)))
+	}
